generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  nom            String
  prenoms        String
  email          String   @unique
  password       String
  poste          String
  matricule      String?
  numeroOrdre    String?
  ordre          String?
  telephone      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Patient {
  id              String    @id @default(uuid())
  idPermanent     String    @unique
  nom             String
  prenom          String
  dateNaissance   DateTime?
  sexe            String?
  telephone       String?
  adresse         String?
  allergies       String[]
  categorie       String?
  groupeSanguin   String?
  chambre         String?
  lit             String?
  service         String?
  typeHospital    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Notification {
  id            String    @id @default(uuid())
  type          String
  destinataire  String
  expediteurId  String
  patientId     String
  referenceId   String
  referenceType String
  titre         String
  contenu       Json
  statut        String    @default("EN_ATTENTE")
  tentatives    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  luAt          DateTime?
}

model PrescriptionMedicale {
  id                String   @id @default(uuid())
  patientId         String
  prescripteurId    String
  statut            String   @default("ACTIVE")
  remarques         String?
  notifierInfirmier Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  medicaments Medicament[]
  ordonnance  Ordonnance?
}

model Medicament {
  id             String    @id @default(uuid())
  prescriptionId String
  nom            String
  dose           String
  quantite       Int       @default(1)
  voie           String?
  frequence      String
  duree          String
  dateDebut      DateTime?
  heureDebut     String?
  instructions   String?
  remarques      String?
  createdAt      DateTime  @default(now())

  prescription PrescriptionMedicale @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model Ordonnance {
  id             String   @id @default(uuid())
  prescriptionId String   @unique
  medicaments    Json
  createdAt      DateTime @default(now())

  prescription PrescriptionMedicale @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model PrescriptionNonMedicale {
  id                String   @id @default(uuid())
  patientId         String
  prescripteurId    String
  statut            String   @default("ACTIVE")
  notifierInfirmier Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  items ItemNonMedical[]
}

model ItemNonMedical {
  id             String    @id @default(uuid())
  prescriptionId String
  type           String
  typeLabel      String?
  description    String
  duree          String?
  frequence      String?
  dateDebut      DateTime?
  heureDebut     String?
  instructions   String?
  createdAt      DateTime  @default(now())

  prescription PrescriptionNonMedicale @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model PrescriptionSurveillance {
  id                String   @id @default(uuid())
  patientId         String
  prescripteurId    String
  statut            String   @default("ACTIVE")
  notes             String?
  notifierInfirmier Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  parametres ParametreSurveillance[]
}

model ParametreSurveillance {
  id             String   @id @default(uuid())
  prescriptionId String
  parametre      String
  frequence      String
  duree          String?
  seuil          String?
  details        Json?
  createdAt      DateTime @default(now())

  prescription PrescriptionSurveillance @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model PrescriptionTransfusion {
  id              String    @id @default(uuid())
  patientId       String
  prescripteurId  String
  urgence         String    @default("n")
  alertes         String?
  renseignements  String
  atcdTransfusion Boolean   @default(false)
  incident        String?
  groupage        String
  hb              Float?
  produit         String
  plaquettes      Float?
  quantite        String?
  datePrevue      DateTime?
  notes           String?
  statut          String    @default("ENVOYEE")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PrescriptionBloc {
  id                 String    @id @default(uuid())
  patientId          String
  prescripteurId     String
  urgence            String    @default("n")
  alertes            String?
  libelle            String
  cote               String?
  dateIntervention   DateTime?
  risqueHemorragique String?
  typeChirurgie      String?
  consignes          String?
  chirurgien         String?
  statut             String    @default("DEMANDE_CPA")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model PrescriptionLabo {
  id             String   @id @default(uuid())
  patientId      String
  prescripteurId String
  urgence        String   @default("n")
  alertes        String?
  renseignements String
  analyses       String[]
  notes          String?
  statut         String   @default("CREEE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PrescriptionImagerie {
  id             String   @id @default(uuid())
  patientId      String
  prescripteurId String
  urgence        String   @default("n")
  alertes        String?
  renseignements String
  statutPatient  String?
  examens        Json
  notes          String?
  statut         String   @default("CREEE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PrescriptionAnapath {
  id             String   @id @default(uuid())
  patientId      String
  prescripteurId String
  urgence        String   @default("n")
  alertes        String?
  typeExamen     String
  data           Json
  statut         String   @default("CREEE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PrescriptionEEG {
  id             String   @id @default(uuid())
  patientId      String
  prescripteurId String
  urgence        String   @default("n")
  alertes        String?
  renseignements String
  typeEEG        String
  remarques      String?
  statut         String   @default("CREEE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PrescriptionKine {
  id                String   @id @default(uuid())
  patientId         String
  prescripteurId    String
  urgence           String   @default("n")
  alertes           String?
  renseignements    String
  typeKine          String
  autreKine         String?
  diagnostic        String?
  contreIndications String[]
  autreContreIndic  String?
  objectifs         String?
  remarques         String?
  statut            String   @default("CREEE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PrescriptionDialyse {
  id             String   @id @default(uuid())
  patientId      String
  prescripteurId String
  urgence        String   @default("n")
  alertes        String?
  renseignements String
  typeDialyse    String
  remarques      String?
  statut         String   @default("CREEE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PrescriptionEndoscopie {
  id             String   @id @default(uuid())
  patientId      String
  prescripteurId String
  urgence        String   @default("n")
  alertes        String?
  renseignements String
  typeExamen     String
  autreExamen    String?
  remarques      String?
  statut         String   @default("CREEE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
